    },
    "LocalizedTextItem": {
      "description": "带有语言标记的文本，带有针对所选语言的可选脚本检查。",
      "type": "object",
      "properties": {
        "@xml:lang": {
          "$ref": "#/$defs/Languages"
        },
        "#text": {
          "type": "string"
        }
      },
      "required": [
        "@xml:lang",
        "#text"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "@xml:lang": {
                "const": "zh"
              }
            },
            "required": [
              "@xml:lang"
            ]
          },
          "then": {
            "properties": {
              "#text": {
                "pattern": "[\\u3400-\\u4DBF\\u4E00-\\u9FFF\\uF900-\\uFAFF]"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "@xml:lang": {
                "const": "en"
              }
            },
            "required": [
              "@xml:lang"
            ]
          },
          "then": {
            "properties": {
              "#text": {
                "not": {
                  "pattern": "[\\u3400-\\u4DBF\\u4E00-\\u9FFF\\uF900-\\uFAFF]"
                }
              }
            }
          }
        }
      ]
    },
    "LocalizedText500Item": {
      "description": "最大长度为 500 个字符的语言标记文本。",
      "allOf": [
        {
          "$ref": "#/$defs/LocalizedTextItem"
        },
        {
          "properties": {
            "#text": {
              "maxLength": 500
            }
          }
        }
      ]
    },
    "AnnualSupplyOrProductionVolumeTextItem": {
      "description": "语言标记的年度供应量或生产量文本。文本必须以实数开头，后跟空格和非空单位或上下文后缀。",
      "allOf": [
        {
          "$ref": "#/$defs/LocalizedText500Item"
        },
        {
          "properties": {
            "#text": {
              "pattern": "^[+-]?(\\d+(\\.\\d*)?|\\.\\d+)([Ee][+-]?\\d+)?\\s+\\S.*$"
            }
          }
        }
      ]
    },
    "AnnualSupplyOrProductionVolumeMultiLang": {
      "description": "带有数字前缀和单位或上下文后缀的多语言年度供应量或生产量文本。",
      "anyOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AnnualSupplyOrProductionVolumeTextItem"
          },
          "uniqueItems": true
        },
        {
          "$ref": "#/$defs/AnnualSupplyOrProductionVolumeTextItem"
        }
      ]
    },
    "LocalizedText1000Item": {
      "description": "最大长度为 1000 个字符的语言标记文本。",
      "allOf": [
        {
          "$ref": "#/$defs/LocalizedTextItem"
        },
        {
          "properties": {
            "#text": {
              "maxLength": 1000
            }
          }
        }
      ]
    },
    "StringMultiLang": {
      "description": "多语言字符串，最大长度为 500 个字符",
      "anyOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/LocalizedText500Item"
          },
          "uniqueItems": true
        },
        {
          "$ref": "#/$defs/LocalizedText500Item"
        }
      ]
    },
    "Int1": {
      "description": "1 位整数",
      "type": "string",
      "pattern": "^[0-9]$"
    },
    "Int5": {
      "description": "5位整数",
      "type": "string",
      "pattern": "^(0|[1-9]\\d{0,4})$"
    },
    "Int6": {
      "description": "6位整数",
      "type": "string",
      "pattern": "^(0|[1-9]\\d{0,5})$"
    },
    "LevelType": {
      "description": "1 位整数，必须等于或大于 0",
      "$ref": "#/$defs/Int1"
    },
    "Perc": {
      "description": "百分比金额",
      "type": "string",
      "pattern": "^(100(\\.0{1,3})?|([0-9]|[1-9][0-9])(\\.\\d{1,3})?)$"
    },
    "MatR": {
      "description": "数学规则",
      "type": "string"
    },
    "MatV": {
      "description": "数学变量或参数",
      "type": "string"
    },
    "Real": {
      "description": "38位实数",
      "type": "string",
      "pattern": "[+-]?(\\d+(\\.\\d*)?|\\.\\d+)([Ee][+-]?\\d+)?$"
    },
    "ST": {
      "description": "短文本，最大长度为 1000 个字符",
      "type": "string",
      "maxLength": 1000
    },
    "String": {
      "description": "最大长度为 500 个字符的字符串。最小长度必须为 1。",
      "type": "string",
      "maxLength": 500,
      "minLength": 1
    },
    "STMultiLang": {
      "description": "多语言短文本，最大长度为 1000 个字符。",
      "anyOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/LocalizedText1000Item"
          },
          "uniqueItems": true
        },
        {
          "$ref": "#/$defs/LocalizedText1000Item"
        }
      ]
    },
    "FTMultiLang": {
      "description": "长度不受限制的多语言自由文本。",
      "anyOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/LocalizedTextItem"
          },
          "uniqueItems": true
        },
        {
          "$ref": "#/$defs/LocalizedTextItem"
        }
      ]
    },
    "AnyXmlElement": {
      "description": "任意 XML 元素负载的 JSON 表示形式。",
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/AnyXmlElement"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/AnyXmlElement"
          }
        }
      ]
    },
    "CommonOther": {
      "description": "ILCD通用：其他扩展容器。容器必须包含至少一个非公共扩展元素；允许命名空间声明，但不计为扩展内容。",
      "type": "object",
      "patternProperties": {
        "^@xmlns(:[A-Za-z_][A-Za-z0-9_.-]*)?$": {
          "type": "string"
        },
        "^(?!(common|xmlns):)([A-Za-z_][A-Za-z0-9_.-]*:)?[A-Za-z_][A-Za-z0-9_.-]*$": {
          "$ref": "#/$defs/AnyXmlElement"
        }
      },
      "additionalProperties": false,
      "not": {
        "propertyNames": {
          "pattern": "^@xmlns(:[A-Za-z_][A-Za-z0-9_.-]*)?$"
        }
      }
    },
    "GlobalReferenceType": {
      "description": "表示对另一个数据集或文件的引用。在 TIDAS 中，引用必须包括类型、refObjectId、版本、uri 和短描述。",
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "@type": {
              "type": "string"
            },
            "@refObjectId": {
              "type": "string",
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
            },
            "@version": {
              "type": "string"
            },
            "@uri": {
              "type": "string"
            },
            "common:shortDescription": {
              "$ref": "#/$defs/STMultiLang"
            }
          },
          "required": [
            "@type",
            "@refObjectId",
            "@uri",
            "@version",
            "common:shortDescription"
          ]
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "@type": {
                "type": "string"
              },
              "@refObjectId": {
                "type": "string",
                "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
              },
              "@version": {
                "type": "string"
              },
              "@uri": {
                "type": "string"
              },
              "common:shortDescription": {
                "$ref": "#/$defs/STMultiLang"
              }
            },
            "required": [
              "@type",
              "@refObjectId",
              "@uri",
              "@version",
              "common:shortDescription"
            ]
          }
        }
      ]
    },
    "GIS": {
      "description": "纬度和经度中的全球地理参考示例：“+42.42;-180”、“0;0”、“13.22 ; -3”",
      "type": "string",
      "pattern": "^\\s*[+-]?((90(\\.0+)?)|([0-8]?\\d(\\.\\d+)?))\\s*;\\s*[+-]?((180(\\.0+)?)|((1[0-7]\\d|[0-9]?\\d)(\\.\\d+)?))\\s*$"
    },
    "UUID": {
      "description": "唯一通用标识符，16 字节十六进制数",
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "Year": {
      "description": "4 位数字年份",
      "type": "integer",
      "minimum": 1000,
      "maximum": 9999
    },
    "dateTime": {
      "description": "日期和时间格式符合。符合 ISO 8601",
      "type": "string",
      "format": "date-time"
    }
  }
}
