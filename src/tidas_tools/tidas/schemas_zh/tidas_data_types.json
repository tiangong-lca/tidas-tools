{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$defs": {
    "CASNumber": {
      "description": "CAS 编号，需要前导零。",
      "type": "string",
      "format": "cas-number",
      "pattern": "^[0-9]{2,7}-[0-9]{2}-[0-9]$"
    },
    "FT": {
      "type": "string",
      "description": "长度不受限制的自由文本。"
    },
    "Languages": {
